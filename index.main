<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Atlantis Premium Water | Pure. Safe. Healthy. | Rawalpindi Pakistan</title>
  <meta name="description" content="Atlantis Premium Water — Pakistan's trusted purified drinking water brand. Available in 500ml, 1.5L, 10L and 19L. Serving Rawalpindi & surrounding areas."/>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
    :root{
      --blue:#0057a8;
      --blue2:#004080;
      --blue3:#e6f0ff;
      --blue4:#c8deff;
      --sky:#0099dd;
      --text:#1a2535;
      --gray:#5a6a7e;
      --light:#f5f8fc;
      --white:#ffffff;
      --border:#dde8f5;
      --green:#00a651;
      --gold:#e6a817;
    }
    html{scroll-behavior:smooth;}
    body{font-family:'Nunito',sans-serif;background:var(--white);color:var(--text);overflow-x:hidden;}

    /* STRIP */
    .strip{
      background:var(--blue);color:#fff;
      display:flex;justify-content:space-between;align-items:center;
      padding:.45rem 5%;font-size:.78rem;font-weight:700;
    }
    .strip-right{display:flex;gap:1.5rem;}
    .strip a{color:#fff;text-decoration:none;opacity:.9;}
    .strip a:hover{opacity:1;text-decoration:underline;}

    /* NAV */
    nav{
      position:sticky;top:0;z-index:200;
      background:#fff;border-bottom:2px solid var(--blue4);
      padding:0 5%;display:flex;align-items:center;
      justify-content:space-between;height:74px;
      box-shadow:0 2px 16px rgba(0,87,168,.09);
    }
    .logo{display:flex;align-items:center;gap:.8rem;text-decoration:none;}
    .logo-circle{
      width:48px;height:48px;
      background:linear-gradient(135deg,var(--blue),var(--sky));
      border-radius:50%;display:flex;align-items:center;
      justify-content:center;color:#fff;font-size:1.4rem;
      font-weight:900;letter-spacing:-.02em;
    }
    .logo-words .logo-main{font-size:1.3rem;font-weight:900;color:var(--blue);line-height:1.1;}
    .logo-words .logo-sub{font-size:.6rem;font-weight:700;color:var(--gray);letter-spacing:.14em;text-transform:uppercase;}
    .nav-links{display:flex;list-style:none;height:74px;}
    .nav-links a{
      display:flex;align-items:center;padding:0 1.1rem;height:100%;
      color:var(--text);text-decoration:none;font-size:.88rem;font-weight:700;
      border-bottom:3px solid transparent;transition:all .2s;
    }
    .nav-links a:hover{color:var(--blue);border-bottom-color:var(--blue);}
    .nav-order{
      background:var(--blue);color:#fff;padding:.65rem 1.5rem;
      border-radius:50px;font-size:.85rem;font-weight:800;
      text-decoration:none;transition:all .2s;white-space:nowrap;
    }
    .nav-order:hover{background:var(--blue2);transform:translateY(-1px);}
    .hbg{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:4px;}
    .hbg span{display:block;width:25px;height:2px;background:var(--text);border-radius:2px;}

    /* HERO */
    .hero{
      background:linear-gradient(150deg,#deeeff 0%,#eef6ff 45%,#d4eaff 100%);
      min-height:90vh;padding:5rem 5% 3rem;
      display:grid;grid-template-columns:1fr 1fr;
      gap:2rem;align-items:center;
      position:relative;overflow:hidden;
    }
    .hero::before{
      content:'';position:absolute;
      right:-80px;top:-80px;width:520px;height:520px;
      background:radial-gradient(circle,rgba(0,153,221,.1),transparent 70%);
      border-radius:50%;pointer-events:none;
    }
    .hero::after{
      content:'';position:absolute;
      left:-60px;bottom:-60px;width:380px;height:380px;
      background:radial-gradient(circle,rgba(0,87,168,.07),transparent 70%);
      border-radius:50%;pointer-events:none;
    }
    .hero-left{position:relative;z-index:2;}
    .hero-chip{
      display:inline-flex;align-items:center;gap:.5rem;
      background:#fff;border:2px solid var(--blue4);color:var(--blue);
      border-radius:50px;padding:.38rem 1.1rem;
      font-size:.75rem;font-weight:800;letter-spacing:.08em;text-transform:uppercase;
      margin-bottom:1.6rem;animation:up .5s ease both;
    }
    .hero-h1{
      font-size:clamp(2.4rem,5vw,4rem);font-weight:900;
      line-height:1.1;color:var(--text);margin-bottom:1.2rem;
      animation:up .5s .08s ease both;
    }
    .hero-h1 span{color:var(--blue);}
    .hero-p{
      font-size:1.02rem;font-weight:600;color:var(--gray);
      line-height:1.78;max-width:470px;margin-bottom:2.2rem;
      animation:up .5s .15s ease both;
    }
    .hero-btns{display:flex;gap:1rem;flex-wrap:wrap;animation:up .5s .22s ease both;}
    .btn-blue{
      background:var(--blue);color:#fff;border:none;
      padding:.9rem 2.2rem;border-radius:50px;
      font-family:'Nunito',sans-serif;font-size:.95rem;font-weight:800;
      cursor:pointer;transition:all .2s;text-decoration:none;display:inline-block;
    }
    .btn-blue:hover{background:var(--blue2);transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,87,168,.28);}
    .btn-outline{
      background:#fff;color:var(--blue);border:2px solid var(--blue);
      padding:.88rem 2rem;border-radius:50px;
      font-family:'Nunito',sans-serif;font-size:.95rem;font-weight:800;
      cursor:pointer;transition:all .2s;text-decoration:none;display:inline-block;
    }
    .btn-outline:hover{background:var(--blue3);}

    /* WhatsApp floating */
    .wa-float{
      position:fixed;bottom:2rem;right:2rem;z-index:500;
      background:#25d366;color:#fff;
      width:58px;height:58px;border-radius:50%;
      display:flex;align-items:center;justify-content:center;
      font-size:1.7rem;text-decoration:none;
      box-shadow:0 4px 20px rgba(37,211,102,.45);
      transition:transform .2s,box-shadow .2s;
    }
    .wa-float:hover{transform:scale(1.1);box-shadow:0 8px 30px rgba(37,211,102,.55);}

    /* Hero bottles */
    .hero-right{
      display:flex;justify-content:center;align-items:flex-end;
      gap:1.2rem;padding-bottom:1.5rem;
      animation:up .7s .15s ease both;position:relative;z-index:2;
    }
    .b-col{display:flex;flex-direction:column;align-items:center;gap:.5rem;}
    .b-col span{font-size:.7rem;font-weight:800;color:var(--blue);text-transform:uppercase;letter-spacing:.06em;}
    .b-wrap{
      background:rgba(255,255,255,.75);border:2px solid var(--blue4);
      border-radius:16px;padding:1rem .8rem;
      display:flex;justify-content:center;align-items:flex-end;
      transition:transform .3s,box-shadow .3s;
    }
    .b-wrap:hover{transform:translateY(-8px);box-shadow:0 16px 40px rgba(0,87,168,.14);}

    /* TRUST BAR */
    .trust{
      background:#fff;border-top:2px solid var(--border);
      border-bottom:2px solid var(--border);
      padding:1.6rem 5%;display:flex;
      align-items:center;justify-content:space-around;
      flex-wrap:wrap;gap:1rem;
    }
    .trust-i{display:flex;align-items:center;gap:.6rem;font-size:.84rem;font-weight:700;color:var(--text);}
    .trust-i em{font-style:normal;font-size:1.25rem;}

    /* SECTIONS */
    .sec{padding:5.5rem 5%;}
    .sec-bg{background:var(--light);}
    .sec-tag{font-size:.72rem;font-weight:800;letter-spacing:.18em;text-transform:uppercase;color:var(--blue);margin-bottom:.6rem;}
    .sec-h{font-size:clamp(1.7rem,3.5vw,2.6rem);font-weight:900;color:var(--text);line-height:1.2;margin-bottom:1rem;}
    .sec-p{font-size:.97rem;font-weight:600;color:var(--gray);line-height:1.8;max-width:540px;}

    /* PRODUCTS */
    .prod-head{text-align:center;margin-bottom:3.5rem;}
    .prod-head .sec-p{margin:0 auto;}
    .prod-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1.5rem;}
    .p-card{
      background:#fff;border:2px solid var(--border);
      border-radius:20px;padding:2rem 1.5rem 1.8rem;
      text-align:center;transition:all .3s;position:relative;
    }
    .p-card:hover{border-color:var(--blue);box-shadow:0 12px 40px rgba(0,87,168,.11);transform:translateY(-5px);}
    .p-card.hot{border-color:var(--blue);box-shadow:0 4px 20px rgba(0,87,168,.1);}
    .hot-tag{
      position:absolute;top:-1px;left:50%;transform:translateX(-50%);
      background:var(--blue);color:#fff;border-radius:0 0 12px 12px;
      font-size:.65rem;font-weight:800;letter-spacing:.08em;text-transform:uppercase;
      padding:.28rem 1.1rem;white-space:nowrap;
    }
    .p-svg-wrap{height:120px;display:flex;align-items:flex-end;justify-content:center;margin-bottom:1rem;}
    .p-size{font-size:2.6rem;font-weight:900;color:var(--blue);line-height:1;}
    .p-unit{font-size:.75rem;font-weight:800;color:var(--gray);letter-spacing:.1em;text-transform:uppercase;margin-bottom:.7rem;}
    .p-name{font-size:.98rem;font-weight:800;color:var(--text);margin-bottom:.4rem;}
    .p-desc{font-size:.78rem;font-weight:600;color:var(--gray);line-height:1.55;margin-bottom:1rem;}
    .p-badge{display:inline-block;background:var(--blue3);color:var(--blue);font-size:.68rem;font-weight:800;padding:.25rem .8rem;border-radius:50px;}

    /* MINERALS TABLE */
    .minerals-sec{background:var(--blue);color:#fff;padding:4rem 5%;}
    .minerals-inner{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;}
    .minerals-text .sec-tag{color:rgba(255,255,255,.7);}
    .minerals-text .sec-h{color:#fff;}
    .minerals-text .sec-p{color:rgba(255,255,255,.8);}
    .mineral-table{width:100%;border-collapse:collapse;margin-top:1.5rem;}
    .mineral-table th{
      background:rgba(255,255,255,.15);color:#fff;
      padding:.7rem 1rem;text-align:left;font-size:.78rem;
      font-weight:800;letter-spacing:.08em;text-transform:uppercase;
    }
    .mineral-table td{
      padding:.65rem 1rem;font-size:.85rem;font-weight:600;
      border-bottom:1px solid rgba(255,255,255,.1);color:rgba(255,255,255,.9);
    }
    .mineral-table tr:last-child td{border-bottom:none;}
    .mineral-table tr:hover td{background:rgba(255,255,255,.05);}
    .mineral-highlight td{color:#fff;font-weight:800;}

    /* ABOUT */
    .about-grid{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center;}
    .about-img-wrap{position:relative;padding-bottom:2rem;}
    .about-img{
      background:linear-gradient(135deg,var(--blue) 0%,var(--sky) 100%);
      border-radius:24px;aspect-ratio:4/5;
      display:flex;align-items:center;justify-content:center;
      flex-direction:column;gap:1rem;color:#fff;
      position:relative;overflow:hidden;
    }
    .about-img::before{
      content:'';position:absolute;inset:0;
      background:radial-gradient(circle at 30% 30%,rgba(255,255,255,.18),transparent 60%);
    }
    .about-img-inner{position:relative;text-align:center;}
    .about-emoji{font-size:4rem;display:block;margin-bottom:.5rem;}
    .about-big{font-size:1.6rem;font-weight:900;}
    .about-sm{font-size:.72rem;font-weight:700;opacity:.8;letter-spacing:.15em;text-transform:uppercase;margin-top:.3rem;}
    .about-stat{
      position:absolute;bottom:-1.5rem;right:-1.5rem;
      background:#fff;border:2px solid var(--border);border-radius:16px;
      padding:1rem 1.4rem;box-shadow:0 8px 30px rgba(0,0,0,.1);
    }
    .about-stat-n{font-size:2rem;font-weight:900;color:var(--blue);line-height:1;}
    .about-stat-l{font-size:.68rem;font-weight:800;color:var(--gray);text-transform:uppercase;letter-spacing:.08em;margin-top:.2rem;}
    .about-text .sec-p{margin-bottom:1rem;}
    .certs{display:flex;gap:.8rem;flex-wrap:wrap;margin-top:1.5rem;}
    .cert-badge{
      display:flex;align-items:center;gap:.5rem;
      background:var(--light);border:2px solid var(--border);
      border-radius:10px;padding:.6rem 1rem;
      font-size:.78rem;font-weight:800;color:var(--text);
    }
    .cert-badge em{font-style:normal;font-size:1.1rem;}
    .feats{display:grid;grid-template-columns:1fr 1fr;gap:.9rem;margin-top:1.5rem;}
    .feat{display:flex;align-items:flex-start;gap:.7rem;padding:.9rem 1rem;background:var(--light);border:2px solid var(--border);border-radius:12px;}
    .feat-ico{width:36px;height:36px;background:var(--blue3);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;}
    .feat strong{display:block;font-size:.82rem;font-weight:800;color:var(--text);margin-bottom:.1rem;}
    .feat span{font-size:.73rem;font-weight:600;color:var(--gray);}

    /* STATS */
    .stats-row{
      background:var(--text);padding:3.5rem 5%;
      display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;
    }
    .stat-box{text-align:center;padding:1rem;border-right:1px solid rgba(255,255,255,.12);}
    .stat-box:last-child{border-right:none;}
    .stat-n{font-size:2.6rem;font-weight:900;color:var(--sky);line-height:1;margin-bottom:.3rem;}
    .stat-l{font-size:.75rem;font-weight:700;color:rgba(255,255,255,.6);text-transform:uppercase;letter-spacing:.1em;}

    /* WHY */
    .why-head{text-align:center;margin-bottom:3.5rem;}
    .why-head .sec-p{margin:0 auto;}
    .why-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;}
    .why-card{
      background:#fff;border:2px solid var(--border);
      border-radius:20px;padding:2rem 1.8rem;transition:all .3s;
    }
    .why-card:hover{border-color:var(--blue);box-shadow:0 8px 30px rgba(0,87,168,.1);transform:translateY(-4px);}
    .why-ico{width:52px;height:52px;background:var(--blue3);border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.5rem;margin-bottom:1.2rem;}
    .why-card h3{font-size:1rem;font-weight:800;color:var(--text);margin-bottom:.6rem;}
    .why-card p{font-size:.83rem;font-weight:600;color:var(--gray);line-height:1.7;}

    /* CONTACT */
    .contact-grid{display:grid;grid-template-columns:1fr 1.1fr;gap:5rem;align-items:start;}
    .contact-cards{display:flex;flex-direction:column;gap:.9rem;margin-top:2rem;}
    .c-card{display:flex;align-items:center;gap:.9rem;padding:1.1rem 1.3rem;background:var(--light);border:2px solid var(--border);border-radius:14px;transition:border-color .2s;text-decoration:none;}
    .c-card:hover{border-color:var(--blue);}
    .c-ico{width:44px;height:44px;background:var(--blue3);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.15rem;flex-shrink:0;}
    .c-card strong{display:block;font-size:.7rem;font-weight:800;color:var(--blue);text-transform:uppercase;letter-spacing:.1em;margin-bottom:.15rem;}
    .c-card span{font-size:.88rem;font-weight:700;color:var(--text);}
    .form-box{background:var(--light);border:2px solid var(--border);border-radius:20px;padding:2.2rem;}
    .form-box h3{font-size:1.3rem;font-weight:900;color:var(--text);margin-bottom:1.5rem;}
    .fg{margin-bottom:1.1rem;}
    .fg label{display:block;font-size:.72rem;font-weight:800;color:var(--gray);text-transform:uppercase;letter-spacing:.1em;margin-bottom:.35rem;}
    .fg input,.fg textarea,.fg select{
      width:100%;background:#fff;border:2px solid var(--border);
      border-radius:10px;color:var(--text);
      padding:.8rem 1rem;font-family:'Nunito',sans-serif;
      font-size:.9rem;font-weight:600;outline:none;
      transition:border-color .2s,box-shadow .2s;
    }
    .fg input:focus,.fg textarea:focus,.fg select:focus{border-color:var(--blue);box-shadow:0 0 0 3px rgba(0,87,168,.1);}
    .fg select option{background:#fff;}
    .fg textarea{resize:vertical;min-height:110px;}
    .frow{display:grid;grid-template-columns:1fr 1fr;gap:1rem;}
    .fsub{
      width:100%;background:var(--blue);color:#fff;border:none;
      border-radius:10px;padding:1rem;
      font-family:'Nunito',sans-serif;font-size:.95rem;font-weight:800;
      cursor:pointer;transition:all .2s;margin-top:.4rem;letter-spacing:.02em;
    }
    .fsub:hover{background:var(--blue2);box-shadow:0 6px 20px rgba(0,87,168,.3);}
    .wa-btn{
      width:100%;background:#25d366;color:#fff;border:none;
      border-radius:10px;padding:1rem;
      font-family:'Nunito',sans-serif;font-size:.95rem;font-weight:800;
      cursor:pointer;transition:all .2s;margin-top:.6rem;
      display:flex;align-items:center;justify-content:center;gap:.5rem;
      text-decoration:none;
    }
    .wa-btn:hover{background:#1ebe5c;box-shadow:0 6px 20px rgba(37,211,102,.3);}
    .fsuccess{display:none;margin-top:.8rem;padding:.9rem;background:#e6f9ef;border:2px solid #b2dfca;border-radius:10px;color:var(--green);font-size:.85rem;font-weight:700;text-align:center;}
    .ferror{display:none;color:#d9534f;font-size:.72rem;font-weight:700;margin-top:.3rem;}

    /* MAP */
    .map-sec{padding:0;}
    .map-sec iframe{width:100%;height:380px;border:none;display:block;}

    /* FOOTER */
    footer{background:var(--text);color:rgba(255,255,255,.6);padding:3.5rem 5% 2rem;}
    .ft{display:flex;justify-content:space-between;gap:3rem;padding-bottom:2.5rem;border-bottom:1px solid rgba(255,255,255,.1);flex-wrap:wrap;}
    .ft-brand{max-width:270px;}
    .ft-brand .logo-main{color:#fff;}
    .ft-brand .logo-sub{color:rgba(255,255,255,.45);}
    .ft-brand p{font-size:.82rem;font-weight:600;line-height:1.75;margin-top:.9rem;color:rgba(255,255,255,.5);}
    .ft-col h4{font-size:.72rem;font-weight:800;text-transform:uppercase;letter-spacing:.12em;color:#fff;margin-bottom:.9rem;}
    .ft-col ul{list-style:none;display:flex;flex-direction:column;gap:.55rem;}
    .ft-col a{color:rgba(255,255,255,.55);text-decoration:none;font-size:.83rem;font-weight:600;transition:color .2s;}
    .ft-col a:hover{color:#fff;}
    .ft-bottom{display:flex;justify-content:space-between;align-items:center;padding-top:1.5rem;font-size:.75rem;flex-wrap:wrap;gap:.5rem;}
    .ft-bottom a{color:rgba(255,255,255,.5);text-decoration:none;}
    .ft-bottom a:hover{color:#fff;}

    /* ANIMATIONS */
    @keyframes up{from{opacity:0;transform:translateY(20px);}to{opacity:1;transform:translateY(0);}}
    .rev{opacity:0;transform:translateY(22px);transition:opacity .6s ease,transform .6s ease;}
    .rev.in{opacity:1;transform:translateY(0);}

    /* MOBILE MENU */
    .mob-menu{display:none;position:fixed;inset:0;background:#fff;z-index:300;flex-direction:column;align-items:center;justify-content:center;gap:2rem;}
    .mob-menu.open{display:flex;}
    .mob-menu a{font-size:1.5rem;font-weight:900;color:var(--text);text-decoration:none;}
    .mob-menu a:hover{color:var(--blue);}
    .mob-x{position:absolute;top:1.3rem;right:1.5rem;background:none;border:none;font-size:2rem;cursor:pointer;color:var(--gray);}

    /* RESPONSIVE */
    @media(max-width:1100px){
      .prod-grid{grid-template-columns:repeat(2,1fr);}
      .minerals-inner{grid-template-columns:1fr;}
      .about-grid{grid-template-columns:1fr;gap:3rem;}
      .stats-row{grid-template-columns:repeat(2,1fr);}
      .stat-box:nth-child(2){border-right:none;}
      .why-grid{grid-template-columns:1fr 1fr;}
      .contact-grid{grid-template-columns:1fr;gap:2.5rem;}
    }
    @media(max-width:768px){
      .strip{font-size:.7rem;flex-direction:column;gap:.3rem;text-align:center;}
      nav{padding:0 4%;}
      .hero{padding:3.5rem 4% 2rem;grid-template-columns:1fr;min-height:auto;text-align:center;}
      .hero-p{margin:0 auto 2rem;}
      .hero-btns{justify-content:center;}
      .hero-right{margin-top:1.5rem;gap:.8rem;}
      .sec{padding:3.5rem 4%;}
      .minerals-sec{padding:3rem 4%;}
      .stats-row{padding:2.5rem 4%;}
      .why-grid{grid-template-columns:1fr;}
      .feats,.frow{grid-template-columns:1fr;}
      .form-box{padding:1.5rem;}
      footer{padding:2.5rem 4%;}
      .ft{flex-direction:column;gap:1.8rem;}
      .ft-bottom{flex-direction:column;text-align:center;}
    }
    @media(max-width:640px){
      .nav-links,.nav-order{display:none;}
      .hbg{display:flex;}
      .prod-grid{grid-template-columns:1fr 1fr;gap:1rem;}
      .hero-right{gap:.6rem;}
      .b-wrap{padding:.6rem .5rem;}
    }
  </style>
</head>
<body>

<!-- WHATSAPP FLOAT -->
<a class="wa-float" href="https://wa.me/923246188876?text=Hi%20Atlantis!%20I%20want%20to%20place%20an%20order." target="_blank" title="Order on WhatsApp">💬</a>

<!-- TOP STRIP -->
<div class="strip">
  <span>🇵🇰 Serving Rawalpindi & Surrounding Areas — Pure. Safe. Fresh.</span>
  <div class="strip-right">
    <a href="tel:0516131864">📞 051-6131864</a>
    <a href="mailto:atlantiswater@gmail.com">✉ atlantiswater@gmail.com</a>
  </div>
</div>

<!-- NAV -->
<nav>
  <a href="#home" class="logo">
    <div class="logo-circle">A</div>
    <div class="logo-words">
      <div class="logo-main">Atlantis</div>
      <div class="logo-sub">Premium Water</div>
