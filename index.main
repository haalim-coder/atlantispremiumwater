<script>
  // Scroll reveal
  const revs = document.querySelectorAll('.rev');
  const obs = new IntersectionObserver((entries) => {
    entries.forEach((e, i) => {
      if (e.isIntersecting) {
        setTimeout(() => e.target.classList.add('in'), i * 55);
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.08 });
  revs.forEach(r => obs.observe(r));

  // Mobile menu
  function toggleMenu() {
    document.getElementById('mobMenu').classList.toggle('open');
  }

  // ─── SHEETDB API ───
  const SHEETDB_URL = 'https://sheetdb.io/api/v1/c0az08qlmc4nw';

  // ─── FORM VALIDATION + SUBMIT ───
  function showError(id, msg) {
    const el = document.getElementById(id);
    el.textContent = msg;
    el.style.display = 'block';
  }
  function clearErrors() {
    document.querySelectorAll('.ferror').forEach(e => e.style.display = 'none');
  }
  function validatePhone(p) {
    return /^(\+92|0092|0)?[3][0-9]{9}$/.test(p.replace(/\s/g, ''));
  }

  async function submitForm() {
    clearErrors();
    const firstName = document.getElementById('f_fname').value.trim();
    const lastName  = document.getElementById('f_lname').value.trim();
    const phone     = document.getElementById('f_phone').value.trim();
    const address   = document.getElementById('f_address').value.trim();
    const product   = document.getElementById('f_product').value;
    const message   = document.getElementById('f_message').value.trim();

    let valid = true;
    if (!firstName) { showError('e_fname', 'First name is required.'); valid = false; }
    if (!lastName)  { showError('e_lname', 'Last name is required.'); valid = false; }
    if (!phone)     { showError('e_phone', 'Phone number is required.'); valid = false; }
    else if (!validatePhone(phone)) { showError('e_phone', 'Enter a valid Pakistani number (e.g. 0300 1234567).'); valid = false; }
    if (!address)   { showError('e_address', 'Delivery address is required.'); valid = false; }
    if (!product)   { showError('e_product', 'Please select a product.'); valid = false; }
    if (!valid) return;

    const btn = document.querySelector('.fsub');
    btn.disabled = true;
    btn.textContent = 'Sending...';

    try {
      const res = await fetch(SHEETDB_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ data: [{
          timestamp: new Date().toLocaleString('en-PK', {timeZone:'Asia/Karachi'}),
          firstName, lastName, phone, address, product,
          message: message || '—'
        }]})
      });
      if (!res.ok) throw new Error('Network error');
      document.getElementById('fsuccess').style.display = 'block';
      document.getElementById('f_fname').value = '';
      document.getElementById('f_lname').value = '';
      document.getElementById('f_phone').value = '';
      document.getElementById('f_address').value = '';
      document.getElementById('f_product').value = '';
      document.getElementById('f_message').value = '';
      setTimeout(() => document.getElementById('fsuccess').style.display = 'none', 7000);
    } catch(err) {
      alert('Could not send order. Please try WhatsApp instead.');
    }
    btn.disabled = false;
    btn.textContent = 'Send Order Request →';
  }

  // ─── ADMIN PANEL ───
  const ADMIN_PASS = 'atlantis2025';

  function openAdmin() {
    const pass = prompt('Enter admin password:');
    if (pass !== ADMIN_PASS) { alert('Wrong password!'); return; }
    document.getElementById('adminPanel').style.display = 'flex';
    loadOrders();
  }
  function closeAdmin() {
    document.getElementById('adminPanel').style.display = 'none';
  }

  async function loadOrders() {
    document.getElementById('adminTable').innerHTML = '<tr><td colspan="7" style="text-align:center;padding:2rem;">Loading orders...</td></tr>';
    try {
      const res = await fetch(SHEETDB_URL);
      const data = await res.json();
      if (!data.length) {
        document.getElementById('adminTable').innerHTML = '<tr><td colspan="7" style="text-align:center;padding:2rem;color:#888;">No orders yet.</td></tr>';
        return;
      }
      document.getElementById('adminCount').textContent = data.length + ' orders';
      document.getElementById('adminTable').innerHTML = data.reverse().map(o => `
        <tr>
          <td>${o.timestamp||'—'}</td>
          <td>${o.firstName||''} ${o.lastName||''}</td>
          <td>${o.phone||'—'}</td>
          <td>${o.address||'—'}</td>
          <td><strong>${o.product||'—'}</strong></td>
          <td>${o.message||'—'}</td>
        </tr>`).join('');
    } catch(e) {
      document.getElementById('adminTable').innerHTML = '<tr><td colspan="7" style="text-align:center;padding:2rem;color:red;">Failed to load orders.</td></tr>';
    }
  }
</script>

<!-- ADMIN PANEL OVERLAY -->
<div id="adminPanel" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.7);align-items:center;justify-content:center;padding:1rem;">
  <div style="background:#fff;border-radius:20px;width:100%;max-width:900px;max-height:90vh;overflow:hidden;display:flex;flex-direction:column;">
    <div style="background:#0057a8;color:#fff;padding:1.2rem 1.8rem;display:flex;justify-content:space-between;align-items:center;">
      <div>
        <div style="font-size:1.1rem;font-weight:900;">📋 Atlantis Orders Dashboard</div>
        <div id="adminCount" style="font-size:.78rem;opacity:.8;margin-top:.2rem;"></div>
      </div>
      <div style="display:flex;gap:.8rem;align-items:center;">
        <button onclick="loadOrders()" style="background:rgba(255,255,255,.2);color:#fff;border:none;border-radius:8px;padding:.5rem 1rem;font-weight:700;cursor:pointer;font-size:.85rem;">🔄 Refresh</button>
        <button onclick="closeAdmin()" style="background:rgba(255,255,255,.2);color:#fff;border:none;border-radius:8px;padding:.5rem 1rem;font-weight:700;cursor:pointer;font-size:.85rem;">✕ Close</button>
      </div>
    </div>
    <div style="overflow:auto;flex:1;padding:1.2rem;">
      <table style="width:100%;border-collapse:collapse;font-size:.82rem;">
        <thead>
          <tr style="background:#f5f8fc;">
            <th style="padding:.7rem 1rem;text-align:left;font-weight:800;color:#0057a8;border-bottom:2px solid #dde8f5;">Time</th>
            <th style="padding:.7rem 1rem;text-align:left;font-weight:800;color:#0057a8;border-bottom:2px solid #dde8f5;">Name</th>
            <th style="padding:.7rem 1rem;text-align:left;font-weight:800;color:#0057a8;border-bottom:2px solid #dde8f5;">Phone</th>
            <th style="padding:.7rem 1rem;text-align:left;font-weight:800;color:#0057a8;border-bottom:2px solid #dde8f5;">Address</th>
            <th style="padding:.7rem 1rem;text-align:left;font-weight:800;color:#0057a8;border-bottom:2px solid #dde8f5;">Product</th>
            <th style="padding:.7rem 1rem;text-align:left;font-weight:800;color:#0057a8;border-bottom:2px solid #dde8f5;">Message</th>
          </tr>
        </thead>
        <tbody id="adminTable"></tbody>
      </table>
    </div>
  </div>
</div>
</body>
</html>
